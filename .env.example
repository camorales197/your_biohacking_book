# Root .env for docker-compose local development

# Required: OpenRouter API Key (get at https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Required: Resend API Key (get at https://resend.com — free tier: 3k/month)
RESEND_API_KEY=your_resend_api_key_here

# Optional: sender address (use onboarding@resend.dev for testing)
EMAIL_FROM=onboarding@resend.dev

# Optional: override default models
ARCHITECT_MODEL=anthropic/claude-opus-4-7
WRITER_MODEL=anthropic/claude-sonnet-4-6
