# Root .env.example — copy to .env for docker-compose local development

# Required: OpenRouter API Key (get at https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: override default models
ARCHITECT_MODEL=google/gemini-2.0-flash-001
WRITER_MODEL=anthropic/claude-haiku-4-5
