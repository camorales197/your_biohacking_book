# OpenRouter API Key - get at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model selection (change to any OpenRouter model slug)
ARCHITECT_MODEL=google/gemini-2.0-flash-001
WRITER_MODEL=anthropic/claude-haiku-4-5

# CORS origins for the frontend (comma-separated)
CORS_ORIGINS=http://localhost:3000

# SQLite database path for LangGraph checkpointer
CHECKPOINT_DB_PATH=./checkpoints.db
