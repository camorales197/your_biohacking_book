# OpenRouter API Key - get at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Powerful models (override to use cheaper ones during dev)
ARCHITECT_MODEL=anthropic/claude-opus-4-7
WRITER_MODEL=anthropic/claude-sonnet-4-6

# Resend - get at https://resend.com (free: 3,000 emails/month)
RESEND_API_KEY=your_resend_api_key_here

# Email sender address
# Use "onboarding@resend.dev" for testing (no domain needed)
# Use "noreply@yourdomain.com" in production (requires domain verification)
EMAIL_FROM=onboarding@resend.dev

# CORS origins for the frontend (comma-separated)
CORS_ORIGINS=http://localhost:3000

# SQLite database path for LangGraph checkpointer
CHECKPOINT_DB_PATH=./checkpoints.db
